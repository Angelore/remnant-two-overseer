<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:svc="using:RemnantOverseer.Services"
             xmlns:loc="using:RemnantOverseer.Services"
             xmlns:vm="using:RemnantOverseer.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="RemnantOverseer.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             svc:FileDialogManager.Register="{Binding}">

  <Grid RowDefinitions="*, Auto">
    <Border Grid.Row="0" Margin="20 20 5 20">
      <ScrollViewer AllowAutoHide="False" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden" Padding="0 0 15 0">
        <StackPanel>
          <!-- Save file location -->
          <Grid RowDefinitions="Auto, Auto">
            <TextBlock Grid.Row="0" Text="{loc:Loc Settings_SaveFileLocation}" FontWeight="DemiBold" FontSize="16" Margin="5"/>
            <Grid Grid.Row="1" ColumnDefinitions="*, Auto">
              <Border Grid.Column="0" BorderThickness="2" CornerRadius="3" BorderBrush="{StaticResource OuterBorderInactiveBrush}" Padding="10 0">
                <TextBlock Height="16" Text="{Binding FilePath}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" VerticalAlignment="Center"/>
              </Border>
              <Button Grid.Column="1" Command="{Binding OpenFileCommand}" ToolTip.Tip="{loc:Loc Settings_ChooseSaveFile}" Margin="5 0 0 0">
                <PathIcon Height="20" Width="20" Foreground="{StaticResource BaseTextColor}"
                        Data="{StaticResource FolderOpenIcon}"/>
              </Button>
            </Grid>
          </Grid>

          <Separator Background="{StaticResource OuterBorderInactiveColor}" Height="2" Margin="0 15 0 0"/>

          <!-- Toggles -->
          <CheckBox IsChecked="{Binding EnableVersionCheck}"
                    Content="{loc:Loc Settings_EnableVersionChecking}" Margin="0 15 0 0"/>
          <CheckBox IsChecked="{Binding ShowTips}"
                    Content="{loc:Loc Settings_EnableLocationSpecificHints}" />
          <CheckBox IsChecked="{Binding ShowToolkitLinks}"
                    Content="{loc:Loc Settings_DisplayToolkitLinks}" />

          <Separator Background="{StaticResource OuterBorderInactiveColor}" Height="2" Margin="0 15 0 0"/>

          <!-- Language -->
          <Grid RowDefinitions="Auto, Auto, Auto" Margin="0 20 0 0">
            <TextBlock Grid.Row="0" Text="{loc:Loc Settings_Language}" FontWeight="DemiBold" FontSize="16" Margin="5 5 5 10"/>
            <ComboBox Grid.Row="1" ItemsSource="{Binding SupportedCultures}" SelectedItem="{Binding SelectedCulture, Mode=TwoWay}" MinWidth="220" HorizontalAlignment="Left" Margin="5 0 0 0">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="svc:CultureOption">
                  <TextBlock Text="{Binding DisplayName}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Grid.Row="2" Text="{loc:Loc Settings_LanguageRestartHint}" Opacity="0.7" Margin="5 8 5 0"/>
          </Grid>

          <Separator Background="{StaticResource OuterBorderInactiveColor}" Height="2" Margin="0 15 0 0"/>

          <!-- Logging -->
          <Grid RowDefinitions="Auto, Auto" Margin="0 20 0 0">
            <TextBlock Grid.Row="0" Text="{loc:Loc Settings_LoggingAndDebug}" FontWeight="DemiBold" FontSize="16" Margin="5 5 5 10"/>
            <Grid Grid.Row="1" ColumnDefinitions="Auto, Auto, Auto">
              <Button Grid.Column="0" Command="{Binding OpenLogCommand}" Margin="5 0 0 0">
                <StackPanel Orientation="Horizontal">
                  <PathIcon Height="20" Width="20" Foreground="{StaticResource BaseTextColor}"
                            Data="{StaticResource LogIcon}" Margin="0 0 5 0"/>
                  <TextBlock Text="{loc:Loc Settings_OpenLog}" FontWeight="Medium" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <Button Grid.Column="1" Command="{Binding DumpPlayerInfoCommand}" Margin="5 0 0 0">
                <StackPanel Orientation="Horizontal">
                  <PathIcon Height="20" Width="20" Foreground="{StaticResource BaseTextColor}"
                            Data="{StaticResource CharacterIcon}" Margin="0 0 5 0"/>
                  <TextBlock Text="{loc:Loc Settings_DumpPlayerInfoToLog}" FontWeight="Medium" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <Button Grid.Column="2" Command="{Binding ExportSaveCommand}" Margin="5 0 0 0">
                <StackPanel Orientation="Horizontal">
                  <PathIcon Height="20" Width="20" Foreground="{StaticResource BaseTextColor}"
                            Data="{StaticResource ExportIcon}" Margin="0 0 5 0"/>
                  <TextBlock Text="{loc:Loc Settings_ExportSaveData}" FontWeight="Medium" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <!--<Border Grid.Column="0" BorderThickness="2" CornerRadius="3" BorderBrush="{StaticResource OuterBorderInactiveBrush}" Padding="10 0">
                <TextBlock Height="16" Text="{Binding FilePath}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" VerticalAlignment="Center"/>
              </Border>
              <Button Grid.Column="1" Command="{Binding OpenFileCommand}" Content="Click me" Margin="5 0 0 0">
                <PathIcon Height="20" Width="20" Foreground="{StaticResource BaseTextColor}"
                        Data="{StaticResource FolderOpenIcon}"/>
              </Button>-->
            </Grid>
          </Grid>
        </StackPanel>
      </ScrollViewer>
    </Border>
  </Grid>

</UserControl>
